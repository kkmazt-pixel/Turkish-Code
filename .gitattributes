# Line-ending / encoding normalization (doc 37 §11 — repo root path itself
# has a space and lives across OSes; every tracked text file must be LF).
# Git still auto-detects binary vs text for anything not matched below.
* text=auto eol=lf

# Source & config — always LF, diffable as text
*.py     text eol=lf diff=python
*.pyi    text eol=lf diff=python
*.pyx    text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf diff=markdown
*.txt    text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf

# Shell scripts — LF is mandatory (a CRLF shebang line fails to execute on Unix)
*.sh     text eol=lf

# Repo/dotfiles
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Windows-only scripts, if any are ever added, keep native CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary — never diff, never line-ending-convert (doc 37 §11: no accidental
# corruption of committed binaries; also doc 37 §11: model weights are never
# committed at all, this is for legitimate small binaries like icons/fonts)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
*.zip   binary
*.db    binary
*.sqlite  binary
*.sqlite3 binary
