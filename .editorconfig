# Baseline whitespace for all tiers (doc 36 §10, doc 37 §4).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,css,html,yaml,yml,md}]
indent_size = 2

[*.rs]
indent_size = 4

[Makefile]
indent_style = tab
